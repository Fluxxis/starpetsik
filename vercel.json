{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    { "source": "/(.*)\.png", "headers": [{ "key": "Content-Type", "value": "image/png" }] },
    { "source": "/(.*)\.webp", "headers": [{ "key": "Content-Type", "value": "image/webp" }] },
    { "source": "/(.*)\.svg", "headers": [{ "key": "Content-Type", "value": "image/svg+xml" }] },
    { "source": "/(.*)\.gif", "headers": [{ "key": "Content-Type", "value": "image/gif" }] }
  ]
}
