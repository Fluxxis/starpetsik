{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ru/mm2/shop/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/ru/mm2/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/ru/mm2",
      "destination": "/index.html"
    }
  ]
}