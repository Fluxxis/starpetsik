<script async>


  const TRACK_ID_KEY = "trackId";
  const TRACK_URL_PARAM_TD = "_td";
  const TRACK_URL_PARAM_TT = "_tt";
  const TRACK_URL_PARAM_HD = "_hd";
  const TRACK_URL_TT_FRESHNESS_MS = 10 * 60 * 1000;
  const TRACK_ID_FORMAT_RE = /^[A-Za-z0-9]{15}\.\d+$/;
  const DEVICE_HASH_FORMAT_RE = /^[0-9a-f]{16}$/;

  function safeGetTrackIdFromLocalStorage() {
    try {
      return localStorage.getItem(TRACK_ID_KEY);
    } catch (e) {
      return null;
    }
  }

  function isValidTrackId(value) {
    return value != null && String(value).trim() !== "";
  }

  function isValidTrackIdFormat(value) {
    return typeof value === "string" && TRACK_ID_FORMAT_RE.test(value);
  }

  function isValidDeviceHashFormat(value) {
    return typeof value === "string" && DEVICE_HASH_FORMAT_RE.test(value);
  }

  function isTtFresh(ttRaw) {
    if (ttRaw == null || ttRaw === "") return false;
    var tt = Number(ttRaw);
    if (!isFinite(tt) || tt <= 0) return false;
    var diff = Date.now() - tt;
    return diff >= 0 && diff <= TRACK_URL_TT_FRESHNESS_MS;
  }

  function simpleHash(value, seed) {
    var hash = seed || 5381;
    var i = value.length;
    while (i) {
      hash = (hash * 33) ^ value.charCodeAt(--i);
    }
    var hex = (hash >>> 0).toString(16);
    while (hex.length < 8) hex = "0" + hex;
    return hex;
  }

  function getWeakPhysicalDeviceHash() {
    try {
      var w = screen.width || 0;
      var h = screen.height || 0;
      var parts = [
        Math.max(w, h),
        Math.min(w, h),
        window.devicePixelRatio || "",
        screen.colorDepth || "",
        navigator.maxTouchPoints || "",
        navigator.hardwareConcurrency || "",
        navigator.deviceMemory || ""
      ];
      var raw = parts.join("|");
      return simpleHash(raw, 5381) + simpleHash(raw, 52711);
    } catch (e) {
      return "";
    }
  }

  function readUrlTrackParams() {
    try {
      var url = new URL(window.location.href);
      return {
        td: url.searchParams.get(TRACK_URL_PARAM_TD),
        tt: url.searchParams.get(TRACK_URL_PARAM_TT),
        hd: url.searchParams.get(TRACK_URL_PARAM_HD)
      };
    } catch (e) {
      return { td: null, tt: null, hd: null };
    }
  }

  var hashDevice = getWeakPhysicalDeviceHash();

  let fromCookie = getCookieValueByKey(TRACK_ID_KEY);
  const fromLs = safeGetTrackIdFromLocalStorage();
  const urlTrackParams = readUrlTrackParams();

  if (isValidTrackId(fromLs) && !isValidTrackId(fromCookie)) {
    setCookie(TRACK_ID_KEY, fromLs);
  }

  let trackId = getCookieValueByKey(TRACK_ID_KEY);

  function randomDateTimeNow15() {
    return createRandomString(15) + "." + Date.now();
  }

  function canAdoptUrlTd(params) {
    if (!isValidTrackIdFormat(params.td)) return false;
    if (!isTtFresh(params.tt)) return false;
    if (params.hd == null || params.hd === "") return true;
    if (!isValidDeviceHashFormat(params.hd)) return false;
    if (!hashDevice) return true;
    return params.hd === hashDevice;
  }

  if (isValidTrackId(trackId)) {
    if (fromLs !== trackId) {
      try {
        localStorage.setItem(TRACK_ID_KEY, trackId);
      } catch (e) {
      }
    }
  } else if (isValidTrackId(fromLs)) {
    trackId = fromLs;
    setCookie(TRACK_ID_KEY, trackId);
  } else if (canAdoptUrlTd(urlTrackParams)) {
    trackId = urlTrackParams.td;
    setCookie(TRACK_ID_KEY, trackId);
    try {
      localStorage.setItem(TRACK_ID_KEY, trackId);
    } catch (e) {
    }
  } else {
    trackId = randomDateTimeNow15();
    setCookie(TRACK_ID_KEY, trackId);
    try {
      localStorage.setItem(TRACK_ID_KEY, trackId);
    } catch (e) {
    }
  }

  window.dataLayer.push({ track_id: trackId, hash_device: hashDevice });

  if (window.posthog && window.posthog.register) {
    window.posthog.register({ track_id: trackId, hash_device: hashDevice });
  }
